@using HomeworkTracker.Services
@inject UserState UserState
@inject NavigationManager NavManager
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">HomeworkTracker</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        @if (UserState.IsLoggedIn)
        {
            <div class="px-3 py-2 text-white-50 small border-bottom border-secondary mb-1">
                <span class="bi bi-person-fill me-1"></span>
                @UserState.CurrentUserName
                <br />
                <span class="opacity-50">
                    @(UserState.Role == "Teacher" ? "Викладач" : "Студент")
                </span>
            </div>
        }

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Головна
            </NavLink>
        </div>

        @if (UserState.Role == "Teacher")
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teacher/dashboard">
                    <span class="bi bi-journal-plus" aria-hidden="true"></span> Кабінет Викладача
                </NavLink>
            </div>
        }

        @if (UserState.Role == "Student")
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="student/dashboard">
                    <span class="bi bi-list-check" aria-hidden="true"></span> Мої завдання
                </NavLink>
            </div>
        }

        @if (UserState.IsLoggedIn)
        {
            <div class="nav-item px-3 mt-3">
                <button class="btn btn-link nav-link p-0" style="color: rgba(255,255,255,.55)"
                        @onclick="Logout">
                    <span class="bi bi-box-arrow-left" aria-hidden="true"></span> Вийти
                </button>
            </div>
        }

    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        UserState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        UserState.OnChange -= StateHasChanged;
    }

    private void Logout()
    {
        UserState.Logout();
        NavManager.NavigateTo("/");
    }
}