@page "/student/dashboard"
@using HomeworkTracker.Models
@using HomeworkTracker.Services
@using HomeworkTracker.Repositories
@inject IUnitOfWork UnitOfWork
@inject SubmissionService SubmissionService
@inject UserState UserState
@inject NavigationManager NavManager
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Кабінет Студента</PageTitle>

<div class="container mt-4">
    <h2>Кабінет Студента</h2>

    @if (currentStudent == null)
    {
        <p><em>Завантаження...</em></p>
    }
    else
    {
        <p class="text-muted">
            Студент: <strong>@currentStudent.Name</strong> &nbsp;|&nbsp;
            Група: <strong>@(currentStudent.Group?.Name ?? "—")</strong>
        </p>

        <div class="card p-4 shadow-sm mb-4">
            <p class="mb-2">Всього завдань у базі: <strong>@totalAssignments</strong></p>

            @if (!groupAssignments.Any())
            {
                <div class="alert alert-warning">
                    Для вашої групи поки немає жодних завдань.
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var assignment in groupAssignments)
                    {
                        var sub = GetSubmission(assignment.Id);
                        <div class="col-md-6 mb-3">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <h5 class="card-title">@assignment.Title</h5>
                                    <p class="card-text">@assignment.Description</p>
                                    <p class="text-muted small">
                                        Дедлайн: @assignment.Deadline.ToShortDateString()
                                        @if (assignment.IsExpired())
                                        {
                                            <span class="badge bg-danger ms-2">Завершено</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success ms-2">Активне</span>
                                        }
                                    </p>

                                    @if (sub != null)
                                    {
                                        @if (sub.Grade.HasValue)
                                        {
                                            <div class="alert alert-success py-2 mb-0">
                                                <strong>Оцінка: @sub.Grade / @(sub.Assignment?.GradingScale ?? 100) ✓</strong>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark">Відправлено на перевірку ✓</span>
                                        }
                                    }
                                    else if (!assignment.IsExpired())
                                    {
                                        <div class="mt-2">
                                            <textarea class="form-control mb-2" rows="2"
                                                      placeholder="Ваша відповідь..."
                                                      @bind="submissionContents[assignment.Id]"></textarea>
                                            <button class="btn btn-primary btn-sm"
                                                    @onclick="() => SubmitWork(assignment.Id)">
                                                Надіслати роботу
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Дедлайн минув</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private Student? currentStudent;
    private List<Assignment> groupAssignments = new();
    private List<Submission> mySubmissions = new();
    private Dictionary<int, string> submissionContents = new();
    private int totalAssignments;

    protected override async Task OnInitializedAsync()
    {
        if (UserState.Role != "Student")
        {
            NavManager.NavigateTo("/");
            return;
        }

        // Отримуємо поточного студента за ID з UserState
        var user = await UnitOfWork.Users.GetUserByIdAsync(UserState.CurrentUserId);
        currentStudent = user as Student;

        if (currentStudent == null) return;

        // Завантажуємо групу студента
        if (currentStudent.GroupId.HasValue)
            currentStudent.Group = await UnitOfWork.Groups.GetByIdAsync(currentStudent.GroupId.Value);

        // Загальна кількість завдань
        var allAssignments = await UnitOfWork.Assignments.GetAllAsync();
        totalAssignments = allAssignments.Count;

        // Завдання для групи студента — завантажуємо напряму з БД
        if (currentStudent.GroupId.HasValue)
            groupAssignments = await UnitOfWork.Assignments.GetByGroupIdAsync(currentStudent.GroupId.Value);
        else
            groupAssignments = new List<Assignment>();

        foreach (var a in groupAssignments)
            submissionContents[a.Id] = "";

        // Здачі цього студента
        mySubmissions = await UnitOfWork.Submissions.GetByStudentIdAsync(currentStudent.Id);
    }

    private Submission? GetSubmission(int assignmentId) =>
        mySubmissions.FirstOrDefault(s => s.AssignmentId == assignmentId);

    private async Task SubmitWork(int assignmentId)
    {
        if (currentStudent == null) return;
        if (!submissionContents.TryGetValue(assignmentId, out var content)) return;
        if (string.IsNullOrWhiteSpace(content)) return;

        await SubmissionService.Submit(assignmentId, currentStudent.Id, content);

        // Оновлюємо список здач зі свіжими даними
        mySubmissions = await UnitOfWork.Submissions.GetByStudentIdAsync(currentStudent.Id);
        submissionContents[assignmentId] = "";
        StateHasChanged();
    }
}