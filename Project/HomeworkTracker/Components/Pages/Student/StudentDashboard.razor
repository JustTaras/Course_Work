@page "/student/dashboard"
@using HomeworkTracker.Models
@using HomeworkTracker.Services
@using HomeworkTracker.Repositories
@inject IUnitOfWork UnitOfWork
@inject SubmissionService SubmissionService
@rendermode InteractiveServer

<div class="container mt-4">
    <h2>Панель студента</h2>

    @if (currentStudent == null || availableAssignments == null)
{
    <p><em>Завантаження...</em></p>
}
else
    {
        <div class="mb-4">
            <h4>Вітаємо, @currentStudent.Name!</h4>
            <p>Ваша група: <strong>@currentStudent.Group?.Name</strong></p>
        </div>

        <h4>Доступні завдання</h4>
        <div class="row">
            @foreach (var assignment in availableAssignments)
            {
                <div class="col-md-6 mb-3">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@assignment.Title</h5>
                            <p class="card-text">@assignment.Description</p>
                            <p class="text-muted small">Дедлайн: @assignment.Deadline.ToShortDateString()</p>
                            
                            @if (HasSubmitted(assignment.Id))
                            {
                                <span class="badge bg-success">Відправлено</span>
                            }
                            else
                            {
                                <div class="mt-2">
                                    <textarea class="form-control mb-2" placeholder="Ваша відповідь..." @bind="submissionContents[assignment.Id]"></textarea>
                                    <button class="btn btn-primary btn-sm" @onclick="() => SubmitWork(assignment.Id)">
                                        Надіслати роботу
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private Student? currentStudent;
    private List<Assignment> availableAssignments = new();
    private List<Submission> mySubmissions = new();
    private Dictionary<int, string> submissionContents = new();

    protected override async Task OnInitializedAsync()
    {
        // 1. Отримуємо дані студента
        var users = await UnitOfWork.Users.GetAllUsersAsync();
        currentStudent = users.OfType<Student>().FirstOrDefault();

        if (currentStudent != null)
        {
            // 2. Отримуємо завдання групи
            var group = await UnitOfWork.Groups.GetByIdAsync(currentStudent.GroupId ?? 0);
            if (group != null)
            {
                availableAssignments = group.Assignments ?? new List<Assignment>();
                
                // 3. Ініціалізуємо ключі в словнику (КЛЮЧОВИЙ МОМЕНТ)
                foreach (var a in availableAssignments)
                {
                    if (!submissionContents.ContainsKey(a.Id))
                    {
                        submissionContents[a.Id] = "";
                    }
                }
            }

            await LoadSubmissions();
        }
    }

    private async Task LoadSubmissions()
    {
        if (currentStudent == null) return;
        var allAssignments = await UnitOfWork.Assignments.GetAllAsync();
        mySubmissions = allAssignments
            .SelectMany(a => a.Submissions)
            .Where(s => s.StudentId == currentStudent.Id)
            .ToList();
    }

    private bool HasSubmitted(int assignmentId) => 
        mySubmissions.Any(s => s.AssignmentId == assignmentId);

    private async Task SubmitWork(int assignmentId)
    {
        // Додаткова перевірка безпеки
        if (currentStudent == null || !submissionContents.ContainsKey(assignmentId)) return;
        
        var content = submissionContents[assignmentId];
        if (string.IsNullOrWhiteSpace(content)) return;

        await SubmissionService.Submit(assignmentId, currentStudent.Id, content);
        await LoadSubmissions();
        StateHasChanged();
    }
}