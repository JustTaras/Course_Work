@page "/teacher/dashboard"
@using HomeworkTracker.Models
@using HomeworkTracker.Services
@using HomeworkTracker.Repositories
@inject AssignmentService AssignmentService
@inject IUnitOfWork UnitOfWork
@rendermode InteractiveServer

<div class="container mt-4">
    <h2>Панель викладача</h2>

    <div class="card p-4 shadow-sm mb-4">
        <h4>Створити нове завдання</h4>
        <div class="row g-3">
            <div class="col-md-6">
                <label>Назва завдання</label>
                <input type="text" class="form-control" @bind="newAssignment.Title" />
            </div>
            <div class="col-md-3">
                <label>Група</label>
                <select class="form-select" @bind="selectedGroupId">
                    <option value="0">Оберіть групу...</option>
                    @foreach (var g in groups)
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label>Дедлайн</label>
                <input type="date" class="form-control" @bind="newAssignment.Deadline" />
            </div>
            <div class="col-12">
                <label>Опис</label>
                <textarea class="form-control" @bind="newAssignment.Description"></textarea>
            </div>
            <div class="col-12">
                <button class="btn btn-primary" @onclick="CreateTask">Опублікувати</button>
            </div>
        </div>
    </div>

    <h4>Активні завдання</h4>
    <table class="table table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Назва</th>
                <th>Група</th>
                <th>Дедлайн</th>
                <th>Статус</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in assignments)
            {
                <tr>
                    <td>@task.Title</td>
                    <td>@task.Group?.Name</td>
                    <td>@task.Deadline.ToShortDateString()</td>
                    <td>
                        @if (task.IsExpired()) { <span class="badge bg-danger">Завершено</span> }
                        else { <span class="badge bg-success">Активне</span> }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<Assignment> assignments = new();
    private List<Group> groups = new();
    private Assignment newAssignment = new Assignment { Deadline = DateTime.Now.AddDays(7) };
    private int selectedGroupId;

    protected override async Task OnInitializedAsync()
    {
        groups = await UnitOfWork.Groups.GetAllAsync();
        assignments = await AssignmentService.GetActiveAssignments();
    }

    private async Task CreateTask()
    {
        if (selectedGroupId == 0 || string.IsNullOrEmpty(newAssignment.Title)) return;

        // В реальній системі ми б брали ID з авторизації, зараз беремо першого викладача
        var teacher = (await UnitOfWork.Users.GetAllUsersAsync()).OfType<Teacher>().FirstOrDefault();
        
        if (teacher != null)
        {
            await AssignmentService.CreateAssignment(
                newAssignment.Title, 
                newAssignment.Description, 
                newAssignment.Deadline, 
                selectedGroupId, 
                teacher.Id);
            
            // Очищення та оновлення
            newAssignment = new Assignment { Deadline = DateTime.Now.AddDays(7) };
            assignments = await AssignmentService.GetActiveAssignments();
        }
    }
}