@page "/"
@inject NavigationManager NavManager

<div class="container text-center mt-5">
    <h1 class="display-4 fw-bold">Homework Tracker</h1>
    <p class="lead text-muted mb-5">Система управління студентськими роботами</p>

    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm mb-4">
                <div class="card-body py-5">
                    <h2 class="card-title h4 mb-4">Для Студентів</h2>
                    <p class="card-text text-muted mb-4">Переглядайте завдання для вашої групи та завантажуйте готові роботи на перевірку.</p>
                    <button class="btn btn-success btn-lg w-100" @onclick='() => NavManager.NavigateTo("/student")'>
                        Увійти як Студент
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm mb-4">
                <div class="card-body py-5">
                    <h2 class="card-title h4 mb-4">Для Викладачів</h2>
                    <p class="card-text text-muted mb-4">Керуйте завданнями для різних груп, перевіряйте роботи та виставляйте оцінки.</p>
                    <button class="btn btn-primary btn-lg w-100" @onclick='() => NavManager.NavigateTo("/teacher")'>
                        Увійти як Викладач
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>