@page "/student"
@using HomeworkTracker.Models
@using HomeworkTracker.Services
@inject SubmissionService SubService
@inject AssignmentService AssignService

<div class="container mt-4">
    <h2 class="mb-4">Кабінет Студента</h2>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <p class="text-muted mb-2">Всього завдань у базі: @AssignService.GetList().Count()</p>
            <label class="form-label fw-bold">Оберіть вашу групу:</label>
            <select class="form-select w-50" @bind="selectedGroup">
                <option value="">-- Оберіть групу --</option>
                <option value="ІПЗ-3/1">ІПЗ-3/1</option>
                <option value="ІПЗ-3/2">ІПЗ-3/2</option>
                <option value="КН-2/1">КН-2/1</option>
            </select>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(selectedGroup))
    {
        var assignments = AssignService.GetList().Where(a => a.GroupName == selectedGroup).ToList();

        <h4 class="mb-3">Завдання для групи @selectedGroup:</h4>

        @if (assignments.Any())
        {
            @foreach (var item in assignments)
            {
                <div class="card mb-3 border-primary shadow-sm">
                    <div class="card-body">
                        <h5 class="text-primary">@item.Title</h5>
                        <p>@item.Description</p>
                        
                        @if (activeAssignmentId == item.Id)
                        {
                            <div class="mt-3 bg-light p-3 rounded">
                                <label class="form-label small fw-bold">Ваша відповідь:</label>
                                <input type="text" class="form-control mb-2" @bind="submissionLink" placeholder="Введіть посилання або текст роботи" />
                                <button class="btn btn-success btn-sm me-2" @onclick="() => ConfirmSubmission(item.Id)">Відправити</button>
                                <button class="btn btn-secondary btn-sm" @onclick="CancelSubmission">Скасувати</button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-outline-success mt-2" @onclick="() => StartSubmission(item.Id)">Здати роботу</button>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info shadow-sm">Для групи @selectedGroup поки немає активних завдань.</div>
        }
    }
</div>

@code {
    private string selectedGroup = "";
    private int? activeAssignmentId = null;
    private string submissionLink = "";

    private void StartSubmission(int id)
    {
        activeAssignmentId = id;
        submissionLink = "";
    }

    private void CancelSubmission()
    {
        activeAssignmentId = null;
    }

    private void ConfirmSubmission(int id) 
    {
        if (!string.IsNullOrWhiteSpace(submissionLink))
        {
            SubService.SubmitWork(id, "Студент", submissionLink);
            
            activeAssignmentId = null;
            submissionLink = "";
        }
    }
}